{
	"name": "simple-websockets",
	"version": "2.2.2",
	"description": "",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"require": "./dist/index.cjs"
		},
		"./server": {
			"import": "./dist/server.mjs",
			"require": "./dist/server.cjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown src/index.ts src/server.ts --format cjs,esm --dts -d dist",
		"typecheck": "tsc && eslint .",
		"lint": "eslint src/",
		"format": "prettier --check ./**/*.ts",
		"prepare": "husky",
		"format:fix": "prettier --config .prettierrc --write ./**/*.ts"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/osztenkurden/simple-websockets.git"
	},
	"author": "",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/osztenkurden/simple-websockets/issues"
	},
	"homepage": "https://github.com/osztenkurden/simple-websockets#readme",
	"engines": {
		"node": ">=22.18"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@eslint/js": "^9.36.0",
		"@types/browser-or-node": "^1.3.0",
		"@types/node": "^24.12.2",
		"eslint": "^9.36.0",
		"husky": "^9.1.7",
		"prettier": "^3.0.3",
		"tsdown": "^0.21.7",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1"
	},
	"dependencies": {
		"@types/ws": "^8.18.1",
		"browser-or-node": "^1.3.0",
		"events": "^3.3.0",
		"reconnecting-websocket": "^4.4.0",
		"ws": "^8.18.2"
	}
}
