{
	"name": "simple-websockets",
	"version": "2.1.0",
	"description": "",
	"type": "module",
	"main": "./lib/index.cjs",
	"module": "./lib/index.js",
	"exports": {
		".": {
			"import": "./lib/index.js",
			"require": "./lib/index.cjs"
		},
		"./server": {
			"import": "./lib/server.js",
			"require": "./lib/server.cjs"
		}
	},
	"scripts": {
		"test": "jest --coverage",
		"build": "npm run lint && npm test && npm run make-badges && npm run rollup",
		"make-badges": "istanbul-badges-readme",
		"rollup": "tsup src/index.ts src/server.ts --format cjs,esm --dts -d lib",
		"lint": "tsc && eslint ."
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/osztenkurden/simple-websockets.git"
	},
	"author": "",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/osztenkurden/simple-websockets/issues"
	},
	"homepage": "https://github.com/osztenkurden/simple-websockets#readme",
	"devDependencies": {
		"@eslint/js": "^9.36.0",
		"@types/browser-or-node": "^1.3.0",
		"@types/jest": "^30.0.0",
		"@types/node": "^22.18.8",
		"eslint": "^9.36.0",
		"istanbul-badges-readme": "^1.2.1",
		"jest": "^30.2.0",
		"jest-ts-webcompat-resolver": "^1.0.0",
		"prettier": "^2.2.1",
		"ts-jest": "^29.4.4",
		"ts-node": "^10.9.2",
		"tsup": "^8.5.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.45.0"
	},
	"jest": {
		"testPathIgnorePatterns": [
			"<rootDir>/lib/"
		],
		"modulePathIgnorePatterns": [
			"<rootDir>/lib/"
		],
		"projects": [
			"<rootDir>/setup/jest.node.config.ts",
			"<rootDir>/setup/jest.browser.config.ts",
			"<rootDir>/setup/jest.server.config.ts",
			"<rootDir>/setup/jest.utils.config.ts"
		],
		"collectCoverageFrom": [
			"src/*"
		],
		"coverageReporters": [
			"json-summary",
			"text",
			"lcov"
		]
	},
	"dependencies": {
		"@types/ws": "^8.18.1",
		"browser-or-node": "^1.3.0",
		"events": "^3.3.0",
		"reconnecting-websocket": "^4.4.0",
		"ws": "^8.18.2"
	}
}
